{
  "name": "house-burguer-grill",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Aplicação React da House Burguer Grill com cardápio, carrinho e checkout via WhatsApp.",
  "scripts": {
    "dev": "vite",
    "dev:react": "vite",
    "dev:angular": "npm --prefix frontend-angular start",
    "install:angular": "npm --prefix frontend-angular install",
    "build": "vite build",
    "build:react": "vite build",
    "build:angular": "npm --prefix frontend-angular run build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{html,css,js,jsx,json,md}\" --write",
    "format:check": "prettier \"**/*.{html,css,js,jsx,json,md}\" --check"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "vite": "^7.1.7"
  }
}
